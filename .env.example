# Without these two set, the server runs in DEMO mode (sample listings).
# Set them to return live mobile.de data via your Apify actor.
APIFY_TOKEN=
CARDATA_ACTOR_ID=your-username/mobile-de-scraper

# Free-tier result cap and the upgrade link shown in tool output.
CARDATA_FREE_LIMIT=10
CARDATA_UPGRADE_URL=https://example.com
